<Window x:Class="MarsRover.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        Title="MARS ROVER &#8211; Vadász Dénes Informatika Verseny 2026"
        Width="1600" Height="950"
        MinWidth="1200" MinHeight="800"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}"
        Loaded="Window_Loaded">

    <Window.Resources>
        <Style x:Key="PanelBorder" TargetType="Border">
            <Setter Property="Background" Value="#221822"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="BorderBrush" Value="#3A2A35"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="PanelTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8A7E85"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="BigValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E8DDD3"/>
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="Consolas"/>
        </Style>

        <Style x:Key="SmallLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6A5E65"/>
            <Setter Property="FontSize" Value="10"/>
        </Style>

        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background" Value="#E8632B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F4A623"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#3A2A35"/>
                    <Setter Property="Foreground" Value="#6A5E65"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="500"/>
            <ColumnDefinition Width="420"/>
        </Grid.ColumnDefinitions>

        <!-- BAL OLDAL: TÉRKÉP + VEZÉRLŐ -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Fejléc -->
            <Border Grid.Row="0" Style="{StaticResource PanelBorder}" Margin="8,8,4,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="18" Height="18" Fill="#E8632B" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <StackPanel>
                            <TextBlock Text="MARS ROVER MISSION CONTROL" Foreground="#E8632B"
                                       FontSize="16" FontWeight="Bold" FontFamily="Consolas"/>
                            <TextBlock x:Name="TxtSubtitle" Text="Vadász Dénes Informatika Verseny 2026"
                                       Foreground="#6A5E65" FontSize="10"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                        <TextBlock Text="Időkeret (óra):" Foreground="#8A7E85" VerticalAlignment="Center"
                                   FontSize="12" Margin="0,0,6,0"/>
                        <TextBox x:Name="TxtHours" Width="60" Text="48" FontSize="14" FontFamily="Consolas"
                                 Background="#2A1A25" Foreground="#E8DDD3" BorderBrush="#3A2A35"
                                 VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                                 Padding="4,4"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                        <TextBlock Text="Animáció:" Foreground="#8A7E85" VerticalAlignment="Center"
                                   FontSize="12" Margin="0,0,6,0"/>
                        <Slider x:Name="SpeedSlider" Width="100" Minimum="50" Maximum="1000" Value="200"
                                VerticalAlignment="Center" IsSnapToTickEnabled="True" TickFrequency="50"/>
                        <TextBlock x:Name="TxtAnimSpeed" Text="200ms" Foreground="#E8DDD3" FontSize="11"
                                   VerticalAlignment="Center" Margin="6,0,0,0" FontFamily="Consolas"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3" Orientation="Horizontal">
                        <Button x:Name="BtnStart" Content="&#9654; INDÍTÁS" Style="{StaticResource ActionBtn}"
                                Click="BtnStart_Click" Margin="0,0,6,0"/>
                        <Button x:Name="BtnPause" Content="SZÜNET" Style="{StaticResource ActionBtn}"
                                Click="BtnPause_Click" IsEnabled="False" Padding="10,10"/>
                        <Button x:Name="BtnExportLog" Content="NAPLÓ" Style="{StaticResource ActionBtn}"
                                Click="BtnExportLog_Click" IsEnabled="False" Padding="10,10" Margin="6,0,0,0"
                                ToolTip="Napló exportálása CSV-be"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- TÉRKÉP CANVAS -->
            <Border Grid.Row="1" Style="{StaticResource PanelBorder}" Margin="8,4,4,4">
                <Grid>
                    <Canvas x:Name="MapCanvas" ClipToBounds="True"/>
                    <Border x:Name="NightOverlay" Background="#44000020" IsHitTestVisible="False"
                            Visibility="Collapsed" CornerRadius="8"/>
                    <Border HorizontalAlignment="Left" VerticalAlignment="Top"
                            Background="#88000000" CornerRadius="6" Padding="8,4" Margin="8">
                        <TextBlock x:Name="TxtPhase" Text="NAPPAL" Foreground="#FACC15"
                                   FontSize="13" FontWeight="Bold" FontFamily="Consolas"/>
                    </Border>
                    <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                            Background="#88000000" CornerRadius="6" Padding="8,4" Margin="8">
                        <TextBlock x:Name="TxtTime" Text="00:00 / 48:00"
                                   Foreground="#E8DDD3" FontSize="13" FontFamily="Consolas"/>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource PanelBorder}" Margin="8,0,4,8" Padding="10,6">
                <TextBlock x:Name="TxtStatus" Text="Térkép betöltve. Adj meg időkeretet és nyomj INDÍTÁS-t."
                           Foreground="#8A7E85" FontSize="11" FontFamily="Consolas"
                           TextTrimming="CharacterEllipsis"/>
            </Border>
        </Grid>

        <!-- JOBB OLDAL: MŰSZERFAL -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Margin="0,8,8,8">
            <StackPanel>

                <Border Style="{StaticResource PanelBorder}">
                    <StackPanel>
                        <TextBlock Text="AKKUMULÁTOR" Style="{StaticResource PanelTitle}"/>
                        <TextBlock x:Name="TxtBattery" Text="100" Style="{StaticResource BigValue}"/>
                        <Border Background="#2A1A25" CornerRadius="4" Height="14" Margin="0,8,0,0">
                            <Border x:Name="BatteryBar" Background="#4ADE80" CornerRadius="4"
                                    HorizontalAlignment="Left" Width="380"/>
                        </Border>
                        <TextBlock x:Name="TxtBatteryInfo" Text="Töltés: +10/tick | Fogyasztás: -"
                                   Style="{StaticResource SmallLabel}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource PanelBorder}">
                    <StackPanel>
                        <TextBlock Text="GYŰJTÖTT ÁSVÁNYOK" Style="{StaticResource PanelTitle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <TextBlock Text="ÖSSZESEN" Style="{StaticResource SmallLabel}" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="TxtMineralTotal" Text="0" Style="{StaticResource BigValue}"
                                           Foreground="#E8632B" HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                <TextBlock Text="KÉK" Style="{StaticResource SmallLabel}" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="TxtMineralB" Text="0" Style="{StaticResource BigValue}"
                                           Foreground="#60A5FA" HorizontalAlignment="Center" FontSize="22"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                <TextBlock Text="SÁRGA" Style="{StaticResource SmallLabel}" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="TxtMineralY" Text="0" Style="{StaticResource BigValue}"
                                           Foreground="#FACC15" HorizontalAlignment="Center" FontSize="22"/>
                            </StackPanel>
                            <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                                <TextBlock Text="ZÖLD" Style="{StaticResource SmallLabel}" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="TxtMineralG" Text="0" Style="{StaticResource BigValue}"
                                           Foreground="#4ADE80" HorizontalAlignment="Center" FontSize="22"/>
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,8,0,0">
                            <Border Background="#2A1A25" CornerRadius="4" Height="10"/>
                            <Border x:Name="MineralProgress" Background="#E8632B" CornerRadius="4"
                                    Height="10" HorizontalAlignment="Left" Width="0"/>
                        </Grid>
                        <TextBlock x:Name="TxtMineralPercent" Text="0 / 390 ásvány (0%)"
                                   Style="{StaticResource SmallLabel}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource PanelBorder}">
                    <StackPanel>
                        <TextBlock Text="ROVER STÁTUSZ" Style="{StaticResource PanelTitle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,6">
                                <TextBlock Text="POZÍCIÓ" Style="{StaticResource SmallLabel}"/>
                                <TextBlock x:Name="TxtPosition" Text="(32, 34)" Foreground="#E8DDD3"
                                           FontSize="16" FontFamily="Consolas" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,6">
                                <TextBlock Text="SEBESSÉG" Style="{StaticResource SmallLabel}"/>
                                <TextBlock x:Name="TxtSpeed" Text="Lassú (1 blokk/tick)"
                                           Foreground="#E8DDD3" FontSize="14" FontFamily="Consolas"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,6">
                                <TextBlock Text="TEVÉKENYSÉG" Style="{StaticResource SmallLabel}"/>
                                <TextBlock x:Name="TxtAction" Text="Standby"
                                           Foreground="#F4A623" FontSize="14" FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,6">
                                <TextBlock Text="MEGTETT ÚT" Style="{StaticResource SmallLabel}"/>
                                <TextBlock x:Name="TxtDistance" Text="0 blokk"
                                           Foreground="#E8DDD3" FontSize="14" FontFamily="Consolas"/>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="0">
                                <TextBlock Text="NAP CIKLUS" Style="{StaticResource SmallLabel}"/>
                                <TextBlock x:Name="TxtDayCycle" Text="1. nap"
                                           Foreground="#E8DDD3" FontSize="14" FontFamily="Consolas"/>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="1">
                                <TextBlock Text="FÁZISVÁLTÁS" Style="{StaticResource SmallLabel}"/>
                                <TextBlock x:Name="TxtPhaseChange" Text="16.0 óra múlva"
                                           Foreground="#E8DDD3" FontSize="14" FontFamily="Consolas"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource PanelBorder}" Height="180">
                    <StackPanel>
                        <TextBlock Text="AKKUMULÁTOR TÖRTÉNETE" Style="{StaticResource PanelTitle}"/>
                        <lvc:CartesianChart x:Name="ChartBattery" Height="140"
                                            TooltipPosition="Hidden" LegendPosition="Hidden"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource PanelBorder}" Height="180">
                    <StackPanel>
                        <TextBlock Text="ÁSVÁNYGYŰJTÉS KUMULATÍV" Style="{StaticResource PanelTitle}"/>
                        <lvc:CartesianChart x:Name="ChartMinerals" Height="140"
                                            TooltipPosition="Hidden" LegendPosition="Hidden"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource PanelBorder}" Height="180">
                    <StackPanel>
                        <TextBlock Text="SEBESSÉG ÉS ENERGIA" Style="{StaticResource PanelTitle}"/>
                        <lvc:CartesianChart x:Name="ChartSpeed" Height="140"
                                            TooltipPosition="Hidden" LegendPosition="Hidden"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource PanelBorder}" Height="200">
                    <StackPanel>
                        <TextBlock Text="ESEMÉNYNAPLÓ" Style="{StaticResource PanelTitle}"/>
                        <ListBox x:Name="LogList" Height="160" Background="Transparent"
                                 BorderThickness="0" Foreground="#E8DDD3" FontSize="11"
                                 FontFamily="Consolas" ScrollViewer.CanContentScroll="True">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="4,2"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#B0A8AB"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
