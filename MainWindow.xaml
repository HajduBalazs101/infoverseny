<Window x:Class="MarsRover.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:skia="clr-namespace:SkiaSharp.Views.WPF;assembly=SkiaSharp.Views.WPF"
        Title="MARS ROVER // TERMINAL v2.0"
        Width="1500" Height="920" MinWidth="1100" MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Background="#0A0A0A" Loaded="OnLoaded"
        KeyDown="OnKeyDown">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="420"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ BAL: TÉRKÉP ═══ -->
        <Grid Grid.Column="0">
            <skia:SKElement x:Name="MapCanvas" PaintSurface="OnPaintSurface"
                            MouseWheel="OnMapMouseWheel"
                            MouseLeftButtonDown="OnMapMouseDown"
                            MouseLeftButtonUp="OnMapMouseUp"
                            MouseMove="OnMapMouseMove"/>

            <!-- HUD: Bal felső -->
            <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="14,12"
                    Background="#EE0A0A0A" CornerRadius="3" Padding="12,6">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="█" Foreground="#33FF33" FontSize="16" FontFamily="Consolas" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="MARS ROVER" FontSize="20" FontWeight="Bold" FontFamily="Consolas"
                               Foreground="#33FF33" VerticalAlignment="Center"/>
                    <TextBlock Text=" // VADÁSZ DÉNES 2026" FontSize="12" FontFamily="Consolas"
                               Foreground="#444444" VerticalAlignment="Center" Margin="10,2,0,0"/>
                </StackPanel>
            </Border>

            <!-- HUD: Jobb felső – napszak -->
            <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="14,12"
                    Background="#EE0A0A0A" CornerRadius="3" Padding="12,6">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="TxtPhaseIcon" Text="☀" FontSize="18" FontFamily="Consolas"
                               Foreground="#FFD633" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock x:Name="TxtPhase" Text="NAPPAL" FontSize="16" FontWeight="Bold"
                               FontFamily="Consolas" Foreground="#FFD633" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtClock" Text="  T+0.0h" FontSize="16"
                               FontFamily="Consolas" Foreground="#666666" VerticalAlignment="Center" Margin="12,0,0,0"/>
                </StackPanel>
            </Border>

            <!-- HUD: Bal alsó -->
            <Border HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="14,0,0,12"
                    Background="#EE0A0A0A" CornerRadius="3" Padding="10,5">
                <TextBlock Text="SCROLL: zoom  |  EGÉR: húzás  |  WASD: mozgatás" FontSize="12"
                           FontFamily="Consolas" Foreground="#383838"/>
            </Border>

            <!-- Éjszaka overlay -->
            <Border x:Name="NightOverlay" IsHitTestVisible="False" Opacity="0">
                <Border.Background>
                    <SolidColorBrush Color="#000820" Opacity="0.35"/>
                </Border.Background>
            </Border>
        </Grid>

        <!-- ═══ JOBB: PANEL ═══ -->
        <Border Grid.Column="1" Background="#0D0D0D" BorderBrush="#1C1C1C" BorderThickness="2,0,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="18,16">

                    <!-- RENDSZER -->
                    <TextBlock Text="RENDSZER" Foreground="#33FF33" FontSize="14" FontWeight="Bold" FontFamily="Consolas" Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="ÓRA " Foreground="#888888" FontSize="16" FontFamily="Consolas" FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" x:Name="TxtHours" Width="60" Text="72" Style="{StaticResource CrtTextBox}" FontSize="18"/>
                        <TextBlock Grid.Column="2" Text=" h" Foreground="#555555" FontSize="16" FontFamily="Consolas" VerticalAlignment="Center"/>
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="SPD " Foreground="#888888" FontSize="16" FontFamily="Consolas" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Slider Grid.Column="1" x:Name="SldSpeed" Minimum="20" Maximum="600" Value="80" VerticalAlignment="Center" Margin="4,0,8,0"/>
                        <TextBlock Grid.Column="2" x:Name="TxtTempo" Text="80ms" Foreground="#666666" FontSize="14" FontFamily="Consolas" VerticalAlignment="Center"/>
                    </Grid>

                    <WrapPanel Margin="0,0,0,16">
                        <Button x:Name="BtnGo" Content="▶ START" Style="{StaticResource CrtButton}"
                                Margin="0,0,6,0" FontSize="15" Padding="16,8" Click="BtnGo_Click"/>
                        <Button x:Name="BtnPause" Content="║║" Style="{StaticResource CrtButtonAmber}"
                                IsEnabled="False" Margin="0,0,6,0" FontSize="15" Padding="12,8" Click="BtnPause_Click"/>
                        <Button x:Name="BtnReset" Content="↺ RST" Style="{StaticResource CrtButton}"
                                Margin="0,0,6,0" FontSize="14" Padding="12,8" Click="BtnReset_Click"/>
                        <Button x:Name="BtnCsv" Content="CSV" Style="{StaticResource CrtButton}"
                                IsEnabled="False" FontSize="14" Padding="12,8" Click="BtnCsv_Click"/>
                    </WrapPanel>

                    <!-- Separator -->
                    <Border Height="1" Background="#1C1C1C" Margin="0,0,0,16"/>

                    <!-- AKKUMULÁTOR -->
                    <TextBlock Text="AKKUMULÁTOR" Foreground="#33FF33" FontSize="14" FontWeight="Bold" FontFamily="Consolas" Margin="0,0,0,6"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock x:Name="TxtBatt" Text="100" FontSize="48" FontWeight="Bold"
                                   FontFamily="Consolas" Foreground="#33FF33"/>
                        <StackPanel VerticalAlignment="Bottom" Margin="4,0,0,8">
                            <TextBlock Text="%" FontSize="20" Foreground="#1A8C1A" FontFamily="Consolas"/>
                        </StackPanel>
                        <TextBlock x:Name="TxtDelta" Text="+0.0" FontSize="18" FontFamily="Consolas"
                                   Foreground="#33FF33" VerticalAlignment="Bottom" Margin="14,0,0,10"/>
                    </StackPanel>

                    <TextBlock x:Name="TxtBattBar" FontSize="15" FontFamily="Consolas" Foreground="#33FF33"
                               Text="[████████████████████] 100%" Margin="0,0,0,4"/>

                    <TextBlock x:Name="TxtBattInfo" Text="" Foreground="#555555" FontSize="13"
                               FontFamily="Consolas" Margin="0,0,0,12"/>

                    <!-- Separator -->
                    <Border Height="1" Background="#1C1C1C" Margin="0,0,0,16"/>

                    <!-- ÁSVÁNYOK -->
                    <TextBlock Text="ÁSVÁNYOK" Foreground="#FFB833" FontSize="14" FontWeight="Bold" FontFamily="Consolas" Margin="0,0,0,6"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock x:Name="TxtMinTotal" Text="0" FontSize="48" FontWeight="Bold"
                                   FontFamily="Consolas" Foreground="#FFB833"/>
                        <TextBlock Text=" db" FontSize="18" Foreground="#8C6600" FontFamily="Consolas"
                                   VerticalAlignment="Bottom" Margin="4,0,0,8"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock x:Name="TxtMinB" Text="KÉK:0" FontSize="16" FontFamily="Consolas" Foreground="#4499FF" FontWeight="Bold" Margin="0,0,16,0"/>
                        <TextBlock x:Name="TxtMinY" Text="SÁR:0" FontSize="16" FontFamily="Consolas" Foreground="#FFD633" FontWeight="Bold" Margin="0,0,16,0"/>
                        <TextBlock x:Name="TxtMinG" Text="ZÖL:0" FontSize="16" FontFamily="Consolas" Foreground="#44FF88" FontWeight="Bold"/>
                    </StackPanel>

                    <TextBlock x:Name="TxtMinBar" FontSize="15" FontFamily="Consolas" Foreground="#FFB833"
                               Text="[░░░░░░░░░░░░░░░░░░░░] 0/390" Margin="0,0,0,12"/>

                    <!-- Separator -->
                    <Border Height="1" Background="#1C1C1C" Margin="0,0,0,16"/>

                    <!-- TELEMETRIA -->
                    <TextBlock Text="TELEMETRIA" Foreground="#888888" FontSize="14" FontWeight="Bold" FontFamily="Consolas" Margin="0,0,0,8"/>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" FontSize="15" FontFamily="Consolas" Margin="0,3">
                            <Run Text="POS " Foreground="#666666"/><Run x:Name="RunPos" Text="(32,34)" Foreground="#DDDDDD" FontWeight="Bold"/>
                        </TextBlock>
                        <TextBlock Grid.Row="0" Grid.Column="1" FontSize="15" FontFamily="Consolas" Margin="0,3">
                            <Run Text="SPD " Foreground="#666666"/><Run x:Name="RunSpd" Text="LASSÚ" Foreground="#DDDDDD" FontWeight="Bold"/>
                        </TextBlock>
                        <TextBlock Grid.Row="1" Grid.Column="0" FontSize="15" FontFamily="Consolas" Margin="0,3">
                            <Run Text="ACT " Foreground="#666666"/><Run x:Name="RunAct" Text="STANDBY" Foreground="#FFB833" FontWeight="Bold"/>
                        </TextBlock>
                        <TextBlock Grid.Row="1" Grid.Column="1" FontSize="15" FontFamily="Consolas" Margin="0,3">
                            <Run Text="DST " Foreground="#666666"/><Run x:Name="RunDist" Text="0" Foreground="#DDDDDD" FontWeight="Bold"/>
                        </TextBlock>
                        <TextBlock Grid.Row="2" Grid.Column="0" FontSize="15" FontFamily="Consolas" Margin="0,3">
                            <Run Text="SOL " Foreground="#666666"/><Run x:Name="RunSol" Text="1" Foreground="#DDDDDD" FontWeight="Bold"/>
                        </TextBlock>
                        <TextBlock Grid.Row="2" Grid.Column="1" FontSize="15" FontFamily="Consolas" Margin="0,3">
                            <Run Text="PHZ " Foreground="#666666"/><Run x:Name="RunPhChg" Text="16.0h" Foreground="#DDDDDD" FontWeight="Bold"/>
                        </TextBlock>
                    </Grid>

                    <!-- Separator -->
                    <Border Height="1" Background="#1C1C1C" Margin="0,0,0,16"/>

                    <!-- NAPLÓ -->
                    <TextBlock Text="NAPLÓ" Foreground="#1A8C1A" FontSize="14" FontWeight="Bold" FontFamily="Consolas" Margin="0,0,0,6"/>

                    <Border Background="#080808" CornerRadius="3" Padding="8,6">
                        <ListBox x:Name="LogBox" Height="180" Background="Transparent"
                                 BorderThickness="0" FontSize="13" FontFamily="Consolas"
                                 Foreground="#1A8C1A" ScrollViewer.CanContentScroll="True">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="2,2"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#1A8C1A"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </Border>

                    <!-- Státusz -->
                    <TextBlock x:Name="TxtStatus" Margin="0,14,0,0"
                               Text="> KÉSZ. NYOMD MEG A START GOMBOT._"
                               Foreground="#33FF33" FontSize="14" FontFamily="Consolas" TextWrapping="Wrap" FontWeight="Bold"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
